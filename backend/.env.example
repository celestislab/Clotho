# ==============================================================================
# Oneiro backend configuration — copy to .env and fill in your key.
#   cp .env.example .env
# The real .env is gitignored; never commit your API key.
# ==============================================================================

# --- Planner LLM (Google Gemini, OpenAI-compatible endpoint) ---
LLM_API_KEY=your-gemini-api-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.5-flash

# --- Minecraft connection ---
# In docker compose these are overridden to point at the oneiro-mc service.
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=Oneiro
MC_VERSION=1.21.11
MC_AUTH=offline

# --- Clotho TS bridge location (inside the container) ---
CLOTHO_TS_DIR=/opt/clotho

# --- Loop / logging ---
LOOP_INTERVAL_SECONDS=15
LOG_LEVEL=info
# Start the Observe-Plan-Act loop automatically on boot (compose sets this to true).
AUTO_START_PLANNER=false

# --- Memory & persona ---
# Directory for persistent planner memory (score, achievements, world DB).
# Defaults to data/memory inside the backend working directory.
MEMORY_DIR=data/memory
# The Minecraft username of the player the agent should listen to and
# address in chat. Leave empty to use generic "the player" in prompts.
PLAYER_NAME=

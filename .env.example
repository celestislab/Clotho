# Clotho TS runtime configuration — copy to .env and fill in your key.
#   cp .env.example .env
# The real .env is gitignored; never commit your API key.

# --- Minecraft body connection ---
MC_HOST=127.0.0.1
MC_PORT=25565
MC_USERNAME=Oneiro
MC_AUTH=offline
MC_VERSION=1.21.11

# --- Planner (slow strategic brain) ---
# Google Gemini via its OpenAI-compatible endpoint.
PLANNER_ENABLED=true
PLANNER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
PLANNER_API_KEY=your-gemini-api-key-here
PLANNER_MODEL=gemini-flash-lite-latest
# Temperature stored as integer 0..200 (OpenAI wants 0..2, so 80 = 0.8).
PLANNER_TEMPERATURE=80
PLANNER_MAX_TOKENS=800

# --- Chat brain (fast social replies) ---
CHAT_ENABLED=true
CHAT_MODEL=gemini-flash-lite-latest
CHAT_TEMPERATURE=95
CHAT_MAX_TOKENS=200

# --- Persona (how the agent presents itself) ---
PERSONA_NAME=Oneiro
PERSONA_LANG=ru

# --- Agent loop tuning ---
PLAN_INTERVAL_MS=45000
MAX_STEPS=50
WATCHDOG_TIMEOUT_MS=60000
OBS_INTERVAL_MS=10000

# --- Humanizer (anti-robot timings, milliseconds) ---
HUMANIZE=true
REACT_DELAY_MIN_MS=180
REACT_DELAY_MAX_MS=520
TYPING_CPS=7

LOG_LEVEL=info
